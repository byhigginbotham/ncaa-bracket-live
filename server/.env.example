# Data source: espn (free, no key) | sportradar (needs key) | mock (fake data)
DATA_SOURCE=espn

PORT=3001

# Only needed if DATA_SOURCE=sportradar
# Free trial tier serves 1-year-delayed data — production tier required for current year
# Get a key at https://developer.sportradar.com/
SPORTRADAR_KEY=your_key_here
