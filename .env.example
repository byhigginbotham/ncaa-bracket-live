# Data source: espn (free) | sportradar (needs key) | mock
DATA_SOURCE=espn

# Only needed if DATA_SOURCE=sportradar
SPORTRADAR_KEY=your_key_here

# For Docker: set to your server's LAN/Tailscale address for non-localhost access
# VITE_SERVER_URL=http://YOUR_SERVER_IP:3001

# Additional CORS origins for LAN access (comma-separated)
# CORS_EXTRA=http://YOUR_SERVER_IP:8080
